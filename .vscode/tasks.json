{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "CMake: configure (MinGW)",
            "command": "C:\\cmake\\bin\\cmake.exe",
            "args": [
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_PREFIX_PATH=C:/msys64/mingw64",
                "-DCMAKE_CXX_COMPILER=g++.exe",
                "-DHELLO_CONTACT_BUILD_DESKTOP=ON",
                "${workspaceFolder}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "detail": "CMake configure for HelloContact (run once)"
        },
        {
            "type": "shell",
            "label": "CMake: build",
            "command": "C:\\cmake\\bin\\cmake.exe",
            "args": [
                "--build",
                "${workspaceFolder}/build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "detail": "Build HelloContact using existing CMake build directory"
        },
        {
            "type": "shell",
            "label": "CMake: build terminal only",
            "command": "C:\\cmake\\bin\\cmake.exe",
            "args": [
                "-B",
                "${workspaceFolder}/build",
                "-G",
                "MinGW Makefiles",
                "-DCMAKE_PREFIX_PATH=C:/msys64/mingw64",
                "-DHELLO_CONTACT_BUILD_DESKTOP=OFF",
                "${workspaceFolder}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build",
            "detail": "Terminal-only build (no Qt dependency)"
        }
    ]
}
